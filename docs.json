{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Product Guide",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": {
    "light": "/images/architonx-logomark-in-primary.png",
    "dark": "/images/architonx-logomark-in-primary.png"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "global": {
          "anchors": [
            {
              "anchor": "Home",
              "icon": "house",
              "href": "/"
            },
            {
              "anchor": "Changelog",
              "icon": "scroll-text",
              "href": "https://www.mintlify.com/docs/changelog"
            },
            {
              "anchor": "Help",
              "icon": "life-buoy",
              "href": "https://www.mintlify.com/docs/contact-support"
            }
          ]
        },
        "directory": "card",
        "groups": [
          {
            "group": "Platform",
            "icon": "layers",
            "expanded": true,
            "pages": [
              "platform/quickstart",
              "platform/key-concepts",
              "platform/configuration/settings",
              "platform/configuration/user-management",
              "platform/administration/roles-permissions",
              "platform/administration/workspaces"
            ]
          },
          {
            "group": "Analytics",
            "icon": "chart-bar",
            "expanded": true,
            "pages": [
              "analytics/quickstart",
              "analytics/connect-data",
              "analytics/dashboards/create-dashboard",
              "analytics/reports/scheduled-reports"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "expanded": true,
            "pages": [
              "integrations/quickstart",
              "integrations/authentication",
              "integrations/connectors/crm",
              "integrations/webhooks/configure"
            ]
          }
        ]
      },
      {
        "language": "ar",
        "global": {
          "anchors": [
            {
              "anchor": "الرئيسية",
              "icon": "house",
              "href": "/ar"
            },
            {
              "anchor": "سجل التغييرات",
              "icon": "scroll-text",
              "href": "https://www.mintlify.com/docs/changelog"
            },
            {
              "anchor": "المساعدة",
              "icon": "life-buoy",
              "href": "https://www.mintlify.com/docs/contact-support"
            }
          ]
        },
        "directory": "card",
        "groups": [
          {
            "group": "المنصة",
            "icon": "layers",
            "expanded": true,
            "pages": [
              "ar/platform/quickstart",
              "ar/platform/key-concepts",
              "ar/platform/configuration/settings",
              "ar/platform/configuration/user-management",
              "ar/platform/administration/roles-permissions",
              "ar/platform/administration/workspaces"
            ]
          },
          {
            "group": "التحليلات",
            "icon": "chart-bar",
            "expanded": true,
            "pages": [
              "ar/analytics/quickstart",
              "ar/analytics/connect-data",
              "ar/analytics/dashboards/create-dashboard",
              "ar/analytics/reports/scheduled-reports"
            ]
          },
          {
            "group": "التكاملات",
            "icon": "plug",
            "expanded": true,
            "pages": [
              "ar/integrations/quickstart",
              "ar/integrations/authentication",
              "ar/integrations/connectors/crm",
              "ar/integrations/webhooks/configure"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/architonx-logo-in-secondary-tertiary.png",
    "dark": "/images/architonx-logo-in-primary-secondary.png"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/architonx",
      "linkedin": "https://linkedin.com/company/architonx"
    }
  }
}
